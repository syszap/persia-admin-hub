# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=persia_admin
PG_USER=postgres
PG_PASSWORD=yourpassword

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_long_and_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SQL Server sync (optional) ──────────────────────────────────────────────
SQL_SERVER_CONN=

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── Multi-tenant (optional) ─────────────────────────────────────────────────
MULTI_TENANT=false
DEFAULT_TENANT_ID=default
